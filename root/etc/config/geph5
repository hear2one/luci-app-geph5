config geph5 'geph5'
	option enabled '0'
	option binary_path '/usr/bin/geph5-client'
	option bind_address '127.0.0.1'
	option socks5_port '9909'
	option http_port '9910'
	option auth_token ''
	option allow_direct '0'
	option passthrough_china '0'
	option spoof_dns '0'
	option filter_ads '1'
	option filter_nsfw '0'
	option task_limit ''
