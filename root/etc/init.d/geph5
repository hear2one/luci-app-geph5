#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

NAME="geph5"
CONFIG="geph5"
YAML_FILE="/var/etc/geph5.yaml"

extra_command "generate" "Generate the runtime YAML configuration"

bool_value() {
	[ "$1" = "1" ] && printf 'true' || printf 'false'
}

generate_config() {
	local bind_address bind_endpoint socks5_port http_port auth_token
	local allow_direct passthrough_china spoof_dns filter_ads filter_nsfw task_limit

	config_load "$CONFIG"
	config_get bind_address geph5 bind_address "127.0.0.1"
	config_get socks5_port geph5 socks5_port "9909"
	config_get http_port geph5 http_port "9910"
	config_get auth_token geph5 auth_token ""
	config_get_bool allow_direct geph5 allow_direct 0
	config_get_bool passthrough_china geph5 passthrough_china 0
	config_get_bool spoof_dns geph5 spoof_dns 0
	config_get_bool filter_ads geph5 filter_ads 1
	config_get_bool filter_nsfw geph5 filter_nsfw 0
	config_get task_limit geph5 task_limit ""

	case "$bind_address" in
		*[!0-9A-Fa-f:.]*|'')
			logger -t geph5 "invalid listen address"
			return 1
			;;
	esac
	case "$bind_address" in
		*:*) bind_endpoint="[$bind_address]" ;;
		*) bind_endpoint="$bind_address" ;;
	esac

	case "$socks5_port:$http_port" in
		*[!0-9:]*|:*|*:)
			logger -t geph5 "invalid proxy port configuration"
			return 1
			;;
	esac
	if [ "$socks5_port" -lt 1 ] || [ "$socks5_port" -gt 65535 ] || \
	   [ "$http_port" -lt 1 ] || [ "$http_port" -gt 65535 ]; then
		logger -t geph5 "proxy ports must be between 1 and 65535"
		return 1
	fi

	if [ -n "$auth_token" ] && ! printf '%s' "$auth_token" | grep -Eq '^[0-9]{24}$'; then
		logger -t geph5 "auth token must contain exactly 24 digits"
		return 1
	fi

	case "$task_limit" in
		''|*[!0-9]*) task_limit="null" ;;
	esac

	umask 077
	mkdir -p "${YAML_FILE%/*}"

	cat > "${YAML_FILE}.tmp" <<-EOF
	socks5_listen: "${bind_endpoint}:${socks5_port}"
	http_proxy_listen: "${bind_endpoint}:${http_port}"
	pac_listen: null
	control_listen: null
	control_listen_unix: null
	exit_constraint: auto
	allow_direct: $(bool_value "$allow_direct")
	cache: /tmp/geph5.db
	broker:
	  priority_race:
	    '0':
	      fronted:
	        front: https://www.cdn77.com/
	        host: 1826209743.rsc.cdn77.org
	        override_dns: null
	    '500':
	      fronted:
	        front: https://vuejs.org/
	        host: svitania-naidallszei-2.netlify.app
	        override_dns: null
	tunneled_broker: null
	broker_keys:
	  master: 88c1d2d4197bed815b01a22cadfc6c35aa246dddb553682037a118aebfaa3954
	  mizaru_free: 0558216cbab7a9c46f298f4c26e171add9af87d0694988b8a8fe52ee932aa754
	  mizaru_plus: cf6f58868c6d9459b3a63bc2bd86165631b3e916bad7f62b578cd9614e0bcb3b
	  mizaru_bw: 
	port_forward: []
	vpn: false
	vpn_fd: null
	spoof_dns: $(bool_value "$spoof_dns")
	passthrough_china: $(bool_value "$passthrough_china")
	dry_run: false
	credentials:
	  secret: "${auth_token}"
	sess_metadata:
	  filter:
	    ads: $(bool_value "$filter_ads")
	    nsfw: $(bool_value "$filter_nsfw")
	task_limit: ${task_limit}
	EOF

	chmod 0600 "${YAML_FILE}.tmp"
	mv -f "${YAML_FILE}.tmp" "$YAML_FILE"
}

generate() {
	generate_config
}

start_service() {
	local enabled prog auth_token

	config_load "$CONFIG"
	config_get_bool enabled geph5 enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get prog geph5 binary_path "/usr/bin/geph5-client"
	config_get auth_token geph5 auth_token ""

	if [ ! -x "$prog" ]; then
		logger -t geph5 "geph5-client is missing or not executable: $prog"
		return 1
	fi

	if ! printf '%s' "$auth_token" | grep -Eq '^[0-9]{24}$'; then
		logger -t geph5 "auth token must contain exactly 24 digits"
		return 1
	fi

	generate_config || return 1

	procd_open_instance
	procd_set_param command "$prog" -c "$YAML_FILE"
	procd_set_param limits nofile="65535"
	procd_set_param env HOME="/root" TMPDIR="/tmp"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 3600 5 5
	procd_set_param term_timeout 10
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG"
}
