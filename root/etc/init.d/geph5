#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

CONF="geph5"
PROG=$(uci -q get $CONF.global.binary_path)

start_service() {
    config_load $CONF
    local enabled
    config_get_bool enabled global enabled 0

    [ "$enabled" -eq 1 ] || return 0

    # 简单的检查，如果找不到程序记录一条日志并退出
    if [ ! -x "$PROG" ]; then
        logger -t geph5 "Error: Binary not found at $PROG"
        return 1
    fi

    local username password auth_token socks5_port socks5_addr http_port http_addr
    config_get username global username
    config_get password global password
    config_get auth_token global auth_token
    config_get socks5_port global socks5_port "9909"
    config_get socks5_addr global socks5_addr "0.0.0.0"
    config_get http_port global http_port "9919"
    config_get http_addr global http_addr "0.0.0.0"

    procd_open_instance
    # 设定启动命令，这里假设 geph5-client 的参数格式
    procd_set_param command "$PROG" connect
    
    # 如果有用户名密码
    if [ -n "$username" ] && [ -n "$password" ]; then
        procd_append_param command --username "$username" --password "$password"
    fi
    # 如果有 token
    if [ -n "$auth_token" ]; then
        procd_append_param command --credential "$auth_token"
    fi

    # 设定端口
    procd_append_param command --socks5-listen "$socks5_addr:$socks5_port"
    procd_append_param command --http-listen "$http_addr:$http_port"

    # 关键：将日志输出重定向到系统日志，不写本地文件
    procd_set_param stderr 1
    procd_set_param stdout 1
    
    # 进程守护，挂掉自动重启
    procd_set_param respawn
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "$CONF"
}
