#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

CONF="geph5"
YAML_FILE="/var/etc/geph5.yaml"

start_service() {
    config_load $CONF
    local enabled
    config_get_bool enabled geph5 enabled 0

    [ "$enabled" -eq 1 ] || return 0

    # 读取界面设置
    local prog auth_token socks5_port http_port
    config_get prog geph5 binary_path "/usr/bin/geph5-client"
    config_get auth_token geph5 auth_token ""
    config_get socks5_port geph5 socks5_port "9909"
    config_get http_port geph5 http_port "9919"

    # 检查程序是否存在
    if [ ! -x "$prog" ]; then
        logger -t geph5 "Error: Binary not found at $prog"
        return 1
    fi

    # 检查密钥是否填写
    if [ -z "$auth_token" ]; then
        logger -t geph5 "Error: Auth token is empty!"
        return 1
    fi

    # --- 核心：模板拼接 ---
    # 将用户设置填入硬编码的 YAML 模板中
    mkdir -p /var/etc

    cat <<EOF > $YAML_FILE
socks5_listen: 127.0.0.1:$socks5_port
http_proxy_listen: 127.0.0.1:$http_port
exit_constraint: auto
bridge_mode: ForceBridges
cache: /tmp/geph5.db
passthrough_china: false
spoof_dns: false
task_limit: null
vpn: false
vpn_fd: null

credentials:
  secret: "$auth_token"

sess_metadata:
  filter:
    ads: true
    nsfw: false

broker:
  priority_race:
    '0':
      fronted:
        front: https://www.cdn77.com/
        host: 1826209743.rsc.cdn77.org
        override_dns: null
    '500':
      fronted:
        front: https://www.vuejs.org/
        host: svitania-naidallszei-3.netlify.app
        override_dns:
        - 75.2.60.5:443

broker_keys:
  master: 88c1d2d4197bed815b01a22cadfc6c35aa246dddb553682037a118aebfaa3954
  mizaru_free: 0558216cbab7a9c46f298f4c26e171add9af87d0694988b8a8fe52ee932aa754
  mizaru_plus: cf6f58868c6d9459b3a63bc2bd86165631b3e916bad7f62b578cd9614e0bcb3b
  mizaru_bw: 
EOF

    # --- 启动进程 ---
    procd_open_instance
    # 使用 -c 加载生成的配置文件
    procd_set_param command "$prog" -c "$YAML_FILE"
    
    # 日志输出到系统日志 (logread)
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_set_param respawn
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "$CONF"
}
