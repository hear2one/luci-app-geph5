#!/bin/sh

# OpenWrt helper libraries such as jshn.sh intentionally probe unset
# variables, so nounset (-u) is not compatible with them.
set -e

UPLOAD_FILE="/tmp/geph5-client.upload"
DEST_FILE="/usr/bin/geph5-client"
INIT_SCRIPT="/etc/init.d/geph5"

json_status() {
	. /usr/share/libubox/jshn.sh

	local configured_path installed running size checksum
	configured_path="$(uci -q get geph5.geph5.binary_path || printf '%s' "$DEST_FILE")"
	installed=0
	running=0
	size=0
	checksum=""

	[ -x "$configured_path" ] && installed=1
	if "$INIT_SCRIPT" running >/dev/null 2>&1; then
		running=1
	fi
	if [ -f "$configured_path" ]; then
		size="$(wc -c < "$configured_path" | tr -d ' ')"
		checksum="$(sha256sum "$configured_path" | awk '{print $1}')"
	fi

	json_init
	json_add_boolean installed "$installed"
	json_add_boolean running "$running"
	json_add_string path "$configured_path"
	json_add_int size "$size"
	json_add_string sha256 "$checksum"
	json_add_boolean config_exists "$([ -s /var/etc/geph5.yaml ] && printf 1 || printf 0)"
	json_dump
}

validate_x86_64_elf() {
	local ident machine machine_high

	# Keep this check limited to BusyBox utilities shipped by ImmortalWrt.
	# ELF64 little-endian identification bytes: 7f 45 4c 46 02 01.
	ident="$(dd if="$1" bs=1 count=6 2>/dev/null)"
	[ "$ident" = "$(printf '\177ELF\002\001')" ] || return 1

	# ELF e_machine for x86-64 is little-endian 3e 00. Shell variables cannot
	# contain NUL, so compare the low byte and verify that deleting NUL from
	# the high byte leaves no data.
	machine="$(dd if="$1" bs=1 skip=18 count=1 2>/dev/null)"
	[ "$machine" = ">" ] || return 1
	machine_high="$(dd if="$1" bs=1 skip=19 count=1 2>/dev/null | tr -d '\000' | wc -c | tr -d ' ')"
	[ "$machine_high" = "0" ]
}

install_upload() {
	local size was_running enabled backup
	[ -f "$UPLOAD_FILE" ] || {
		echo "没有找到上传文件" >&2
		exit 2
	}

	size="$(wc -c < "$UPLOAD_FILE" | tr -d ' ')"
	[ "$size" -gt 0 ] && [ "$size" -le 134217728 ] || {
		rm -f "$UPLOAD_FILE"
		echo "客户端文件大小必须在 1 字节到 128 MiB 之间" >&2
		exit 2
	}

	validate_x86_64_elf "$UPLOAD_FILE" || {
		rm -f "$UPLOAD_FILE"
		echo "上传的文件不是 Linux x86_64 ELF 可执行文件" >&2
		exit 2
	}

	backup="${DEST_FILE}.backup"
	rm -f "$backup" "${DEST_FILE}.new"
	cp "$UPLOAD_FILE" "${DEST_FILE}.new"
	chmod 0755 "${DEST_FILE}.new"

	if ! "${DEST_FILE}.new" --help >/dev/null 2>&1; then
		rm -f "${DEST_FILE}.new" "$UPLOAD_FILE"
		echo "geph5-client 兼容性检查失败（ABI 不匹配或缺少运行库）" >&2
		exit 3
	fi

	was_running=0
	if "$INIT_SCRIPT" running >/dev/null 2>&1; then
		was_running=1
		"$INIT_SCRIPT" stop
	fi

	[ ! -e "$DEST_FILE" ] || mv -f "$DEST_FILE" "$backup"
	mv -f "${DEST_FILE}.new" "$DEST_FILE"
	rm -f "$UPLOAD_FILE"
	rm -f "$backup"

	uci set geph5.geph5.binary_path="$DEST_FILE"
	uci commit geph5
	"$INIT_SCRIPT" enable
	logger -t geph5 "已安装上传的 x86_64 geph5-client（$size 字节）"

	enabled="$(uci -q get geph5.geph5.enabled || printf 0)"
	if [ "$was_running" -eq 1 ] || [ "$enabled" = "1" ]; then
		"$INIT_SCRIPT" restart
	fi

	json_status
}

case "${1:-}" in
	status)
		json_status
		;;
	log)
		logread -e geph5 -l 200 2>/dev/null || true
		;;
	install-upload)
		install_upload
		;;
	start)
		uci set geph5.geph5.enabled='1'
		uci commit geph5
		"$INIT_SCRIPT" start
		json_status
		;;
	stop)
		"$INIT_SCRIPT" stop
		uci set geph5.geph5.enabled='0'
		uci commit geph5
		json_status
		;;
	restart)
		uci set geph5.geph5.enabled='1'
		uci commit geph5
		"$INIT_SCRIPT" restart
		json_status
		;;
	generate)
		"$INIT_SCRIPT" generate
		json_status
		;;
	*)
		echo "usage: $0 {status|log|install-upload|start|stop|restart|generate}" >&2
		exit 1
		;;
esac
